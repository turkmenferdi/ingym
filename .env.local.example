# Supabase proje ayarlarından kopyala (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Google AI Studio (https://aistudio.google.com/apikey) — ücretsiz
GEMINI_API_KEY=YOUR-GEMINI-API-KEY
# Web push (web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=
# Supabase service role (cron için, RLS bypass) — GİZLİ, paylaşma
SUPABASE_SERVICE_ROLE_KEY=
